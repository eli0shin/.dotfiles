{
  "defaultThinkingLevel": "low",
  "quietStartup": true,
  "collapseChangelog": true,
  "doubleEscapeAction": "tree",
  "compaction": {
    "enabled": true,
    "reserveTokens": 16384,
    "keepRecentTokens": 20000
  },
  "retry": {
    "enabled": true,
    "maxRetries": 3,
    "baseDelayMs": 2000,
    "provider": {
      "maxRetryDelayMs": 60000
    }
  },
  "permissionGate": {
    "bash": {
      "askCommands": [
        "rm",
        "sudo"
      ],
      "ask": [
        "\\bgit\\s+push\\b(?:(?![;&|]).)*(?:(?:^|\\s)(?:refs/heads/)?(?:main|master)(?=$|\\s)|:(?:refs/heads/)?(?:main|master)(?=$|\\s))",
        "\\bgit\\s+reset\\s+--hard\\b",
        "\\b(chmod|chown)\\b.*777"
      ],
      "block": []
    }
  },
  "packages": [
    "npm:pi-web-access",
    "npm:@benvargas/pi-exa-mcp"
  ],
  "extensions": [
    "-extensions/otel-tracing/index.ts"
  ]
}
