[
  {
    "command": "uv",
    "install": "curl -LsSf https://astral.sh/uv/install.sh | bash",
    "update": "uv self update"
  },
  {
    "command": "rustup",
    "install": "curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y",
    "update": "rustup self update"
  },
  {
    "command": "claude",
    "install": "curl -fsSL https://claude.ai/install.sh | bash",
    "update": "claude update"
  },
  {
    "command": "opencode",
    "install": "curl -fsSL https://opencode.ai/install | bash",
    "update": "opencode upgrade"
  },
  {
    "command": "bun",
    "install": "curl -fsSL https://bun.sh/install | bash",
    "update": "bun upgrade"
  },
  {
    "command": "pi",
    "install": "curl -fsSL https://pi.dev/install.sh | bash",
    "update": "pi update --all"
  },
  {
    "command": "repos",
    "install": "curl -fsSL https://raw.githubusercontent.com/eli0shin/repos/main/install.sh | bash",
    "update": "repos update"
  },
  {
    "command": "cli-lsp-client",
    "install": "curl -fsSL https://raw.githubusercontent.com/eli0shin/cli-lsp-client/main/install.sh | bash",
    "update": "cli-lsp-client update"
  },
  {
    "command": "mcp-controller",
    "install": "curl -fsSL https://raw.githubusercontent.com/eli0shin/mcp-controller/main/install.sh | bash",
    "update": "mcp-controller update"
  },
  {
    "command": "pup",
    "platforms": {
      "darwin": {
        "install": "mkdir -p ~/.local/bin && gh release download --repo datadog-labs/pup --pattern 'pup_*_Darwin_arm64.tar.gz' --output /tmp/pup.tar.gz --clobber && tar xzf /tmp/pup.tar.gz -C /tmp && mv /tmp/pup ~/.local/bin/pup",
        "update": "mkdir -p ~/.local/bin && gh release download --repo datadog-labs/pup --pattern 'pup_*_Darwin_arm64.tar.gz' --output /tmp/pup.tar.gz --clobber && tar xzf /tmp/pup.tar.gz -C /tmp && mv /tmp/pup ~/.local/bin/pup"
      },
      "linux": {
        "install": "mkdir -p ~/.local/bin && gh release download --repo datadog-labs/pup --pattern 'pup_*_Linux_x86_64.tar.gz' --output /tmp/pup.tar.gz --clobber && tar xzf /tmp/pup.tar.gz -C /tmp && mv /tmp/pup ~/.local/bin/pup",
        "update": "mkdir -p ~/.local/bin && gh release download --repo datadog-labs/pup --pattern 'pup_*_Linux_x86_64.tar.gz' --output /tmp/pup.tar.gz --clobber && tar xzf /tmp/pup.tar.gz -C /tmp && mv /tmp/pup ~/.local/bin/pup"
      }
    }
  },
  {
    "command": "omf",
    "check": "fish -lc 'type -q omf'",
    "install": "curl https://raw.githubusercontent.com/oh-my-fish/oh-my-fish/master/bin/install | fish -c 'source - --noninteractive --yes'",
    "update": "fish -lc 'omf update'"
  },
  {
    "command": "sqlit",
    "install": "uv tool install sqlit-tui",
    "update": "uv tool upgrade sqlit-tui"
  },
  {
    "command": "aws",
    "platforms": {
      "darwin": {
        "install": "curl \"https://awscli.amazonaws.com/AWSCLIV2.pkg\" -o \"/tmp/AWSCLIV2.pkg\" && sudo installer -pkg /tmp/AWSCLIV2.pkg -target /"
      },
      "linux": {
        "install": "curl \"https://awscli.amazonaws.com/awscli-exe-linux-x86_64.zip\" -o \"/tmp/awscliv2.zip\" && rm -rf /tmp/aws && unzip -q /tmp/awscliv2.zip -d /tmp && sudo /tmp/aws/install",
        "update": "curl \"https://awscli.amazonaws.com/awscli-exe-linux-x86_64.zip\" -o \"/tmp/awscliv2.zip\" && rm -rf /tmp/aws && unzip -q /tmp/awscliv2.zip -d /tmp && sudo /tmp/aws/install --update"
      }
    }
  },
  {
    "command": "kubectl",
    "platforms": {
      "darwin": {
        "install": "mkdir -p ~/.local/bin && curl -L -o ~/.local/bin/kubectl \"https://dl.k8s.io/release/$(curl -L -s https://dl.k8s.io/release/stable.txt)/bin/darwin/arm64/kubectl\" && chmod +x ~/.local/bin/kubectl",
        "update": "mkdir -p ~/.local/bin && curl -L -o ~/.local/bin/kubectl \"https://dl.k8s.io/release/$(curl -L -s https://dl.k8s.io/release/stable.txt)/bin/darwin/arm64/kubectl\" && chmod +x ~/.local/bin/kubectl"
      },
      "linux": {
        "install": "mkdir -p ~/.local/bin && curl -L -o ~/.local/bin/kubectl \"https://dl.k8s.io/release/$(curl -L -s https://dl.k8s.io/release/stable.txt)/bin/linux/amd64/kubectl\" && chmod +x ~/.local/bin/kubectl",
        "update": "mkdir -p ~/.local/bin && curl -L -o ~/.local/bin/kubectl \"https://dl.k8s.io/release/$(curl -L -s https://dl.k8s.io/release/stable.txt)/bin/linux/amd64/kubectl\" && chmod +x ~/.local/bin/kubectl"
      }
    }
  },
  {
    "command": "sst",
    "install": "curl -fsSL https://sst.dev/install | bash",
    "update": "sst upgrade"
  },
  {
    "command": "datadog_mcp_cli",
    "install": "curl -sSL https://coterm.datadoghq.com/mcp-cli/install.sh | bash"
  },
  {
    "command": "mcp2cli",
    "install": "uv tool install mcp2cli",
    "update": "uv tool upgrade mcp2cli"
  },
  {
    "command": "docker-scout",
    "check": "docker scout version >/dev/null 2>&1",
    "install": "curl -fsSL https://raw.githubusercontent.com/docker/scout-cli/main/install.sh | bash",
    "update": "curl -fsSL https://raw.githubusercontent.com/docker/scout-cli/main/install.sh | bash"
  }
]
